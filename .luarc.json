{
  "runtime": {
    "version": "LuaJIT",
    "pathStrict": true
  },
  "workspace": {
    "checkThirdParty": false,
    "ignoreDir": [".direnv"],
    "library": ["${3rd}/busted/library"]
  },
  "diagnostics": {
    "globals": ["vim"]
  },
  "type": {
    "checkTableShape": true
  },
  "completion": {
    "callSnippet": "Replace"
  }
}
